# Supabase（建立專案後由 Dashboard → Settings → API 複製）
# 僅 anon key 可放前端；切勿使用 VITE_ 暴露 service_role 或任何 LLM/API 秘密。
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# 以下僅能放在 Edge Function / 後端，禁止 VITE_ 前綴：
# OPENAI_API_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# （選）本月 LLM complete 次數上限：generate-draft 會讀取 profiles.plan；free 預設 40、pro 預設 500
# FREE_PLAN_MONTHLY_LLM=40
# PRO_PLAN_MONTHLY_LLM=500
